{
  "name": "event-cafe-2026",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:app && npm run build:functions",
    "build:app": "tsc -b && vite build",
    "build:functions": "npm --prefix functions run build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:rules": "node ./scripts/with-local-java.mjs firebase --config firebase.rules-test.json emulators:exec --only firestore __RULES_TEST__",
    "test:watch": "vitest",
    "preview": "vite preview",
    "emulators": "node ./scripts/run-firebase-emulators.mjs",
    "emulators:seed": "node ./functions/scripts/seed-emulator.mjs",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:hosting": "firebase deploy --only hosting"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "firebase": "^12.15.0",
    "gsap": "^3.15.0",
    "lucide-react": "^0.554.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.9.5",
    "three": "^0.185.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "firebase-tools": "^15.22.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
